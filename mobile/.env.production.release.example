# Release-critical environment variables for BRDG iOS releases.
# Copy only the values you need into shell env or mobile/.env.production on the release checkout.
# Shell env values override anything loaded from mobile/.env.production.

EXPO_PUBLIC_API_URL=https://api.example.com
IOS_BUNDLE_IDENTIFIER=com.avmillabs.brdg
IOS_BUILD_NUMBER=0
ASC_LIVE_BUILD_NUMBER=0
ASC_BUILD_NUMBER_VERIFIED_AT=2026-03-26T00:00:00Z
IOS_DEVELOPMENT_TEAM=YOURTEAMID

# Optional App Store Connect API key auth for automated build-number lookup and post-upload polling.
ASC_API_KEY_ID=
ASC_API_ISSUER_ID=
ASC_API_KEY_PATH=/absolute/path/to/AuthKey_KEYID.p8
